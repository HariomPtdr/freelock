# Database
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/freelock?retryWrites=true&w=majority

# Auth
JWT_SECRET=your_strong_random_secret_here

# URLs (no trailing slash)
CLIENT_URL=https://your-frontend.onrender.com
SERVER_URL=https://your-backend.onrender.com

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_ACCOUNT_NUMBER=your_account_number

# ImageKit
IMAGEKIT_PRIVATE_KEY=private_xxxxxxxxxxxx
IMAGEKIT_PUBLIC_KEY=public_xxxxxxxxxxxx
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# RealityDefender
REALITY_DEFENDER_API_KEY=your_reality_defender_key
